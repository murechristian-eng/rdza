{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/geocode.ts": {
      "maxDuration": 10
    },
    "api/cadastre-alti.ts": {
      "maxDuration": 10
    },
    "api/urbanisme.ts": {
      "maxDuration": 10
    }
  }
}