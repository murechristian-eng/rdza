{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Lancer Freebuff",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy", "Bypass",
        "-File", "launch-freebuff.ps1"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "icon": "rocket"
    },
    {
      "label": "📦 Build Production",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "🔍 Typecheck",
      "type": "shell",
      "command": "npm",
      "args": ["run", "typecheck"],
      "group": "test",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "🖥️ Dev Server (Vite)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "🌐 Dev Server + API (Vercel)",
      "type": "shell",
      "command": "npx",
      "args": ["vercel", "dev"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "🚢 Déployer sur Vercel",
      "type": "shell",
      "command": "npx",
      "args": ["vercel", "--prod"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🧹 Installer les dépendances",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
